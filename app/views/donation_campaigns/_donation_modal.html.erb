
<div id="donation-modal-overlay" class="modal-overlay" onclick="closeDonationModal(event)" style="display: none;">
  
  <div class="modal-card" dir="rtl" onclick="event.stopPropagation()">
    
    <div class="modal-header">
      <button class="modal-close-btn" onclick="closeDonationModal(event)">✕</button>
      <h2 class="modal-title">פרטי התרומה שלי</h2>
    </div>

    <%= form_with(model: [campaign, Payment.new], local: true, class: "modal-form") do |form| %>
      
      <div class="form-group">
        <%= form.label :name, "שם התורם / תורמת" %>
        <%= form.text_field :name, placeholder: "ישראל ישראלי (או השאר ריק לאנונימי)" %>
      </div>

      <div class="amount-grid">
        <button type="button" class="amount-btn" onclick="selectAmount(this, 180)">₪180<small>נטיעת עץ</small></button>
        <button type="button" class="amount-btn" onclick="selectAmount(this, 260)">₪260<small>נטיעת 2 עצים</small></button>
        <button type="button" class="amount-btn" onclick="selectAmount(this, 360)">₪360<small>נטיעת 3 עצים</small></button>
        <button type="button" class="amount-btn" onclick="selectAmount(this, 1800)">₪1,800<small>בונים מרחב</small></button>
        <button type="button" class="amount-btn" onclick="selectAmount(this, 5000)">₪5,000<small>בוני הגן</small></button>
        <button type="button" class="amount-btn custom-preset-btn" onclick="selectCustomOption(this)">סכום אחר</button>
      </div>

      <div class="form-group amount-input-wrapper" id="custom-amount-wrapper" style="display: none;">
        <%= form.label :amount, "אני רוצה לתרום:" %>
        <%= form.number_field :amount, id: "donation-amount-field", min: 1, step: 1, placeholder: "0.00" %>
      </div>

      <div class="form-checkbox" style="margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
        <input type="checkbox" id="add-note-checkbox" onclick="toggleCommentField()">
        <label for="add-note-checkbox" style="font-weight: 700; cursor: pointer;">רוצה להוסיף הערה?</label>
      </div>

      <div class="form-group" id="comment-input-wrapper" style="display: none;">
        <%= form.label :comment, "ההערה שלך:" %>
        <%= form.text_area :comment, rows: 3, placeholder: "הוסף כאן הערה" %>
      </div>

      <div class="modal-footer">
        <%= form.submit "תרומה", class: "btn-submit-donation" %>
      </div>

    <% end %>

  </div>
</div>
